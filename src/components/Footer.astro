---
const currentYear = new Date().getFullYear();
---

<footer class="bg-brand-navy text-white">
  <!-- Main footer -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-11 h-11 bg-brand-red rounded-full flex items-center justify-center text-white font-display font-bold text-lg shadow-lg" aria-hidden="true">SP</div>
          <div>
            <span class="text-xl font-display font-bold">Salty Papa's</span>
            <span class="block text-xs text-brand-gold tracking-[0.2em] uppercase font-semibold">Shrimp House</span>
          </div>
        </div>
        <p class="text-white/50 text-sm leading-relaxed mt-4">
          Where the Bayou Meets the Beach. Fresh Gulf seafood,
          Cajun spices, and Southern hospitality.
        </p>
        <!-- Social -->
        <div class="flex gap-3 mt-6">
          <a
            href="https://www.facebook.com/saltypapasshrimphouse"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 bg-white/10 rounded-xl flex items-center justify-center text-white/60 hover:bg-brand-red hover:text-white transition-all duration-300"
            aria-label="Visit us on Facebook"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
            </svg>
          </a>
          <a
            href="https://www.yelp.com/biz/salty-papas-shrimp-house-fort-myers"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 bg-white/10 rounded-xl flex items-center justify-center text-white/60 hover:bg-brand-red hover:text-white transition-all duration-300"
            aria-label="Find us on Yelp"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="font-display text-sm font-bold uppercase tracking-wider text-brand-gold mb-6">Navigation</h3>
        <ul class="space-y-3" role="list">
          <li><a href="/" class="text-white/60 hover:text-white transition-colors text-sm">Home</a></li>
          <li><a href="/menu" class="text-white/60 hover:text-white transition-colors text-sm">Menu</a></li>
          <li><a href="/about" class="text-white/60 hover:text-white transition-colors text-sm">About Us</a></li>
          <li><a href="/contact" class="text-white/60 hover:text-white transition-colors text-sm">Contact</a></li>
        </ul>
      </div>

      <!-- Hours -->
      <div>
        <h3 class="font-display text-sm font-bold uppercase tracking-wider text-brand-gold mb-6">Hours</h3>
        <dl class="space-y-3 text-sm">
          <div>
            <dt class="text-white/80 font-semibold">Monday – Sunday</dt>
            <dd class="text-white/50">11:00 AM – 8:30 PM</dd>
          </div>
        </dl>
        <p class="text-xs text-white/30 mt-4">Seating ends at 8:30 PM daily</p>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-display text-sm font-bold uppercase tracking-wider text-brand-gold mb-6">Contact</h3>
        <address class="not-italic text-sm space-y-3">
          <p class="text-white/60">
            15271 McGregor Blvd, Suite 1<br />
            Fort Myers, FL 33908
          </p>
          <p>
            <a href="tel:+12394827272" class="text-white/80 hover:text-brand-gold transition-colors font-semibold">
              (239) 482-7272
            </a>
          </p>
          <p>
            <a href="mailto:info@SaltyPapasShrimpHouse.com" class="text-white/60 hover:text-brand-gold transition-colors text-xs">
              info@SaltyPapasShrimpHouse.com
            </a>
          </p>
        </address>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-white/30">
      <p>&copy; {currentYear} Salty Papa's Shrimp House. All rights reserved.</p>
      <div class="flex items-center gap-2">
        <span class="star-gold text-xs">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
        <span>5 Stars on Yelp</span>
        <span class="mx-2">&bull;</span>
        <span>TripAdvisor Travelers' Choice</span>
      </div>
    </div>
  </div>
</footer>
