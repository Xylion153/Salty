---
const currentYear = new Date().getFullYear();
---

<footer class="bg-brand-navy text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- Brand -->
      <div>
        <h2 class="font-display text-2xl font-bold mb-2">Salty Papa's</h2>
        <p class="text-brand-gold text-sm tracking-widest uppercase mb-4">Shrimp House</p>
        <p class="text-white/70 text-sm leading-relaxed">
          Where the Bayou Meets the Beach. Fresh Gulf seafood, Cajun spices,
          and Southern hospitality in Fort Myers, Florida.
        </p>
      </div>

      <!-- Hours -->
      <div>
        <h3 class="font-display text-lg font-semibold mb-4">Hours</h3>
        <dl class="space-y-2 text-sm text-white/70">
          <div class="flex justify-between">
            <dt>Monday – Sunday</dt>
            <dd>11:00 AM – 8:30 PM</dd>
          </div>
        </dl>
        <p class="text-xs text-white/50 mt-3">Seating ends at 8:30 PM daily</p>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-display text-lg font-semibold mb-4">Visit Us</h3>
        <address class="not-italic text-sm text-white/70 space-y-2">
          <p>15271 McGregor Blvd, Suite 1</p>
          <p>Fort Myers, Florida 33908</p>
          <p class="mt-3">
            <a href="tel:+12394827272" class="text-brand-gold hover:text-white transition-colors">
              (239) 482-7272
            </a>
          </p>
          <p>
            <a href="mailto:info@SaltyPapasShrimpHouse.com" class="text-brand-gold hover:text-white transition-colors">
              info@SaltyPapasShrimpHouse.com
            </a>
          </p>
        </address>

        <!-- Social -->
        <div class="flex gap-4 mt-4">
          <a
            href="https://www.facebook.com/saltypapasshrimphouse"
            target="_blank"
            rel="noopener noreferrer"
            class="text-white/50 hover:text-brand-gold transition-colors"
            aria-label="Visit us on Facebook"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
            </svg>
          </a>
          <a
            href="https://www.yelp.com/biz/salty-papas-shrimp-house-fort-myers"
            target="_blank"
            rel="noopener noreferrer"
            class="text-white/50 hover:text-brand-gold transition-colors"
            aria-label="Find us on Yelp"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12.271 11.826l-2.244-6.163a1.07 1.07 0 00-1.073-.68c-.472.043-3.237.37-3.605.424a1.073 1.073 0 00-.462 1.876l4.508 4.15a1.072 1.072 0 001.684-.257l.522-.997a1.07 1.07 0 00.67-1.353zm-1.484 2.453a1.073 1.073 0 00-1.727.072l-.585.943a1.073 1.073 0 00.205 1.378l3.838 3.438a1.073 1.073 0 001.9-.578c.04-.468.155-3.264.175-3.64a1.073 1.073 0 00-.89-1.108l-2.916-.505z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-white/40">
      <p>&copy; {currentYear} Salty Papa's Shrimp House. All rights reserved.</p>
      <p>15271 McGregor Blvd, Suite 1, Fort Myers, FL 33908</p>
    </div>
  </div>
</footer>
