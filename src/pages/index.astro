---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
  <!-- Hero -->
  <section class="relative bg-brand-navy text-white overflow-hidden">
    <div class="absolute inset-0 placeholder-img opacity-30" aria-hidden="true">
      <span>Hero Image — Restaurant Exterior</span>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32 md:py-44 text-center">
      <p class="text-brand-gold text-sm tracking-[0.3em] uppercase font-semibold mb-4">
        Fort Myers, Florida
      </p>
      <h1 class="font-display text-5xl md:text-7xl font-extrabold leading-tight mb-6">
        Salty Papa's<br />
        <span class="text-brand-gold">Shrimp House</span>
      </h1>
      <p class="text-xl md:text-2xl text-white/80 font-light max-w-2xl mx-auto mb-10">
        Where the Bayou Meets the Beach
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/menu" class="btn-primary text-lg px-10 py-4">View Our Menu</a>
        <a href="/contact" class="btn-outline text-lg px-10 py-4">Find Us</a>
      </div>
    </div>
  </section>

  <!-- Intro -->
  <section class="bg-brand-cream py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="section-heading mb-6">Gulf Coast Flavors,<br />Southern Soul</h2>
        <p class="text-lg text-gray-600 leading-relaxed mb-8">
          At Salty Papa's, we source the freshest seafood from Florida and the South,
          combining bayou spice with Gulf Coast charm. Every dish is made from scratch
          by our two professional chefs, bringing you bold flavors and genuine
          Southern hospitality.
        </p>
        <div class="w-16 h-px bg-brand-gold mx-auto"></div>
      </div>
    </div>
  </section>

  <!-- Featured Highlights -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="section-heading mb-3">What Makes Us Special</h2>
        <p class="section-subheading mx-auto">
          From the Gulf to your plate — here's what keeps folks coming back.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Card 1 -->
        <div class="group bg-brand-cream rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow">
          <div class="h-48 placeholder-img">
            <span>Image — Fresh Shrimp</span>
          </div>
          <div class="p-6">
            <h3 class="font-display text-xl font-bold text-brand-blue mb-2">Fresh Gulf Seafood</h3>
            <p class="text-gray-600 text-sm leading-relaxed">
              Shrimp, scallops, grouper, stone crab — sourced daily from Florida waters
              and prepared to order.
            </p>
          </div>
        </div>

        <!-- Card 2 -->
        <div class="group bg-brand-cream rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow">
          <div class="h-48 placeholder-img">
            <span>Image — Cajun Spices</span>
          </div>
          <div class="p-6">
            <h3 class="font-display text-xl font-bold text-brand-blue mb-2">Bayou-Inspired Recipes</h3>
            <p class="text-gray-600 text-sm leading-relaxed">
              Shrimp &amp; grits, po'boys, gumbo — our recipes bring authentic
              Cajun and Creole flavors to Southwest Florida.
            </p>
          </div>
        </div>

        <!-- Card 3 -->
        <div class="group bg-brand-cream rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow">
          <div class="h-48 placeholder-img">
            <span>Image — Courtyard Patio</span>
          </div>
          <div class="p-6">
            <h3 class="font-display text-xl font-bold text-brand-blue mb-2">Pet-Friendly Patio</h3>
            <p class="text-gray-600 text-sm leading-relaxed">
              Bring your four-legged friend to our courtyard seating — fresh air,
              great food, and everyone's welcome.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Gluten-Free & Allergen Callout -->
  <section class="bg-brand-blue text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display text-2xl md:text-3xl font-bold mb-4">
        Allergy-Friendly Dining
      </h2>
      <p class="text-white/80 text-lg max-w-2xl mx-auto mb-6">
        We maintain dedicated gluten-free fryers and our staff is trained to help
        with allergen concerns. Just ask — we're happy to accommodate.
      </p>
      <a href="/contact" class="btn-primary bg-white text-brand-blue hover:bg-brand-cream">
        Have Questions? Reach Out
      </a>
    </div>
  </section>

  <!-- Hours & Location Quick Strip -->
  <section class="bg-brand-cream py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
        <div>
          <div class="w-12 h-12 bg-brand-blue rounded-full flex items-center justify-center mx-auto mb-4" aria-hidden="true">
            <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-display text-lg font-bold text-brand-navy mb-1">Open Daily</h3>
          <p class="text-gray-600">11:00 AM – 8:30 PM</p>
        </div>
        <div>
          <div class="w-12 h-12 bg-brand-blue rounded-full flex items-center justify-center mx-auto mb-4" aria-hidden="true">
            <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="font-display text-lg font-bold text-brand-navy mb-1">Fort Myers</h3>
          <p class="text-gray-600">15271 McGregor Blvd, Suite 1</p>
        </div>
        <div>
          <div class="w-12 h-12 bg-brand-blue rounded-full flex items-center justify-center mx-auto mb-4" aria-hidden="true">
            <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <h3 class="font-display text-lg font-bold text-brand-navy mb-1">Call Ahead</h3>
          <p class="text-gray-600">
            <a href="tel:+12394827272" class="text-brand-blue hover:text-brand-red transition-colors">(239) 482-7272</a>
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
