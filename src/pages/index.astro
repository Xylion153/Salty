---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
  <!-- Hero -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1615141982883-c7ad0e69fd62?w=1920&q=80"
        alt="Fresh Gulf shrimp and seafood spread"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 overlay-dark"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32 text-center text-white">
      <p class="text-brand-gold text-sm md:text-base tracking-[0.4em] uppercase font-bold mb-6 animate-fade-in">
        Fort Myers, Florida
      </p>
      <h1 class="font-display text-5xl sm:text-6xl md:text-8xl font-black leading-[0.9] mb-6 animate-fade-in">
        Salty Papa's
      </h1>
      <p class="font-display text-2xl sm:text-3xl md:text-4xl text-brand-gold font-bold mb-6 animate-fade-in">
        Shrimp House
      </p>
      <div class="divider-gold mx-auto mb-8 animate-fade-in"></div>
      <p class="text-xl md:text-2xl text-white/80 font-light max-w-2xl mx-auto mb-12 animate-fade-in">
        Where the Bayou Meets the Beach
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center animate-fade-in">
        <a href="/menu" class="btn-primary text-base px-12 py-5">View Our Menu</a>
        <a href="/contact" class="btn-outline text-base px-12 py-5">Find Us</a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-white/50 animate-bounce">
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </section>

  <!-- Intro -->
  <section class="bg-brand-cream py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <p class="text-brand-red font-bold text-sm tracking-[0.3em] uppercase mb-4 animate-on-scroll">Est. Fort Myers</p>
        <h2 class="section-heading mb-8 animate-on-scroll">Gulf Coast Flavors,<br />Southern Soul</h2>
        <p class="text-lg md:text-xl text-gray-600 leading-relaxed mb-8 animate-on-scroll">
          At Salty Papa's, we source the freshest seafood from Florida and the South,
          combining bayou spice with Gulf Coast charm. Every dish is made from scratch
          by our two professional chefs, bringing you bold flavors and genuine
          Southern hospitality.
        </p>
        <div class="divider-gold mx-auto animate-on-scroll"></div>
      </div>
    </div>
  </section>

  <!-- Featured Dishes Showcase -->
  <section class="py-24 md:py-32 bg-white overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-brand-red font-bold text-sm tracking-[0.3em] uppercase mb-4 animate-on-scroll">From Our Kitchen</p>
        <h2 class="section-heading mb-4 animate-on-scroll">Signature Dishes</h2>
        <p class="section-subheading mx-auto animate-on-scroll">
          Bold flavors straight from the Gulf — here's what keeps folks coming back.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Card 1 -->
        <div class="card-hover rounded-2xl overflow-hidden shadow-lg animate-on-scroll delay-1">
          <div class="img-zoom h-64">
            <img
              src="https://images.unsplash.com/photo-1565680018434-b513d5e5fd47?w=600&q=80"
              alt="Fresh Gulf shrimp served on ice"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
          <div class="p-6 bg-white">
            <h3 class="font-display text-xl font-bold text-brand-navy mb-2">Fresh Gulf Seafood</h3>
            <p class="text-gray-500 text-sm leading-relaxed">
              Shrimp, scallops, grouper, stone crab — sourced daily from Florida waters
              and prepared to order.
            </p>
            <a href="/menu" class="inline-block mt-4 text-brand-red font-bold text-sm hover:text-red-700 transition-colors">
              See the menu &rarr;
            </a>
          </div>
        </div>

        <!-- Card 2 -->
        <div class="card-hover rounded-2xl overflow-hidden shadow-lg animate-on-scroll delay-2">
          <div class="img-zoom h-64">
            <img
              src="https://images.unsplash.com/photo-1626645738196-c2a7c87a8f58?w=600&q=80"
              alt="Cajun shrimp and grits with spices"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
          <div class="p-6 bg-white">
            <h3 class="font-display text-xl font-bold text-brand-navy mb-2">Bayou-Inspired Recipes</h3>
            <p class="text-gray-500 text-sm leading-relaxed">
              Shrimp &amp; grits, po'boys, Cajun calamari — authentic bayou flavors
              meet Southwest Florida sunshine.
            </p>
            <a href="/menu" class="inline-block mt-4 text-brand-red font-bold text-sm hover:text-red-700 transition-colors">
              See the menu &rarr;
            </a>
          </div>
        </div>

        <!-- Card 3 -->
        <div class="card-hover rounded-2xl overflow-hidden shadow-lg animate-on-scroll delay-3">
          <div class="img-zoom h-64">
            <img
              src="https://images.unsplash.com/photo-1551024709-8f23befc6f87?w=600&q=80"
              alt="Tropical rum cocktail with garnish"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
          <div class="p-6 bg-white">
            <h3 class="font-display text-xl font-bold text-brand-navy mb-2">Craft Cocktails</h3>
            <p class="text-gray-500 text-sm leading-relaxed">
              Specialty drinks with local Florida rum, Tampa craft beers,
              and fresh-squeezed lemonades.
            </p>
            <a href="/menu#drinks" class="inline-block mt-4 text-brand-red font-bold text-sm hover:text-red-700 transition-colors">
              See drinks &rarr;
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Full-width image break -->
  <section class="relative h-[50vh] md:h-[60vh] parallax-hero" style="background-image: url('https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=1920&q=80');">
    <div class="absolute inset-0 overlay-dark-subtle"></div>
    <div class="relative h-full flex items-center justify-center text-center text-white px-4">
      <div class="animate-on-scroll">
        <p class="text-brand-gold tracking-[0.3em] uppercase font-bold text-sm mb-4">Our Promise</p>
        <h2 class="font-display text-3xl md:text-5xl font-bold max-w-3xl leading-tight">
          "Every plate tells a story of the Gulf Coast"
        </h2>
      </div>
    </div>
  </section>

  <!-- Why Salty Papa's -->
  <section class="py-24 md:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <!-- Left: Image grid -->
        <div class="grid grid-cols-2 gap-4 animate-on-scroll">
          <div class="img-zoom rounded-2xl overflow-hidden shadow-lg">
            <img src="https://images.unsplash.com/photo-1559339352-11d035aa65de?w=400&q=80" alt="Chef preparing seafood dish" class="w-full h-48 md:h-64 object-cover" loading="lazy" />
          </div>
          <div class="img-zoom rounded-2xl overflow-hidden shadow-lg mt-8">
            <img src="https://images.unsplash.com/photo-1533777857889-4be7c70b33f7?w=400&q=80" alt="Restaurant patio dining" class="w-full h-48 md:h-64 object-cover" loading="lazy" />
          </div>
          <div class="img-zoom rounded-2xl overflow-hidden shadow-lg">
            <img src="https://images.unsplash.com/photo-1590759668628-05b0fc34bb70?w=400&q=80" alt="Fresh seafood platter" class="w-full h-48 md:h-64 object-cover" loading="lazy" />
          </div>
          <div class="img-zoom rounded-2xl overflow-hidden shadow-lg mt-8">
            <img src="https://images.unsplash.com/photo-1568901346375-23c9450c58cd?w=400&q=80" alt="Gourmet burger with fries" class="w-full h-48 md:h-64 object-cover" loading="lazy" />
          </div>
        </div>

        <!-- Right: Text -->
        <div>
          <p class="text-brand-red font-bold text-sm tracking-[0.3em] uppercase mb-4 animate-on-scroll">Why Choose Us</p>
          <h2 class="section-heading mb-8 animate-on-scroll">More Than<br />a Meal</h2>
          <div class="space-y-6 animate-on-scroll">
            <div class="flex gap-4">
              <div class="w-12 h-12 bg-brand-red/10 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-brand-red" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
                </svg>
              </div>
              <div>
                <h3 class="font-display text-lg font-bold text-brand-navy">Allergy Friendly</h3>
                <p class="text-gray-500 text-sm mt-1">Dedicated gluten-free fryers and staff trained on allergen protocols.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-12 h-12 bg-brand-red/10 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-brand-red" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
                </svg>
              </div>
              <div>
                <h3 class="font-display text-lg font-bold text-brand-navy">Pet-Friendly Patio</h3>
                <p class="text-gray-500 text-sm mt-1">Bring your four-legged friend to our beautiful courtyard seating.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-12 h-12 bg-brand-red/10 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-brand-red" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-display text-lg font-bold text-brand-navy">Scratch Kitchen</h3>
                <p class="text-gray-500 text-sm mt-1">Everything made in-house from sauces and rubs to desserts.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-12 h-12 bg-brand-red/10 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-brand-red" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6.633 10.5c.806 0 1.533-.446 2.031-1.08a9.041 9.041 0 012.861-2.4c.723-.384 1.35-.956 1.653-1.715a4.498 4.498 0 00.322-1.672V3a.75.75 0 01.75-.75A2.25 2.25 0 0116.5 4.5c0 1.152-.26 2.243-.723 3.218-.266.558.107 1.282.725 1.282h3.126c1.026 0 1.945.694 2.054 1.715.045.422.068.85.068 1.285a11.95 11.95 0 01-2.649 7.521c-.388.482-.987.729-1.605.729H14.23c-.483 0-.964-.078-1.423-.23l-3.114-1.04a4.501 4.501 0 00-1.423-.23H5.904M14.25 9h2.25M5.904 18.75c.083.228.22.442.396.632a2.25 2.25 0 002.372.686l.54-.18c.337-.112.696-.169 1.058-.169H12M5.904 18.75A2.25 2.25 0 015.25 16.5v-7.5A2.25 2.25 0 017.5 6.75h0" />
                </svg>
              </div>
              <div>
                <h3 class="font-display text-lg font-bold text-brand-navy">Tampa Craft Beers</h3>
                <p class="text-gray-500 text-sm mt-1">Rotating selection of local brews paired perfectly with seafood.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Reviews -->
  <section class="bg-brand-navy text-white py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-brand-gold font-bold text-sm tracking-[0.3em] uppercase mb-4 animate-on-scroll">What People Say</p>
        <h2 class="font-display text-3xl md:text-5xl font-bold mb-4 animate-on-scroll">Loved by Locals<br />&amp; Visitors</h2>
        <div class="flex justify-center gap-1 mt-4 animate-on-scroll">
          <span class="star-gold text-2xl">&#9733;</span>
          <span class="star-gold text-2xl">&#9733;</span>
          <span class="star-gold text-2xl">&#9733;</span>
          <span class="star-gold text-2xl">&#9733;</span>
          <span class="star-gold text-2xl">&#9733;</span>
        </div>
        <p class="text-white/50 text-sm mt-2 animate-on-scroll">5 Stars on Yelp &bull; TripAdvisor Travelers' Choice 2025</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-8 card-hover animate-on-scroll delay-1">
          <div class="flex gap-1 mb-4">
            <span class="star-gold">&#9733;</span><span class="star-gold">&#9733;</span><span class="star-gold">&#9733;</span><span class="star-gold">&#9733;</span><span class="star-gold">&#9733;</span>
          </div>
          <p class="text-white/80 leading-relaxed mb-6 italic">
            "Best shrimp &amp; grits I've ever had outside of New Orleans. The andouille cream sauce is incredible. This place is a hidden gem on McGregor!"
          </p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-brand-gold/20 rounded-full flex items-center justify-center text-brand-gold font-bold text-sm">M</div>
            <div>
              <p class="font-bold text-sm">Mike R.</p>
              <p class="text-white/40 text-xs">Yelp Review</p>
            </div>
          </div>
        </div>

        <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-8 card-hover animate-on-scroll delay-2">
          <div class="flex gap-1 mb-4">
            <span class="star-gold">&#9733;</span><span class="star-gold">&#9733;</span><span class="star-gold">&#9733;</span><span class="star-gold">&#9733;</span><span class="star-gold">&#9733;</span>
          </div>
          <p class="text-white/80 leading-relaxed mb-6 italic">
            "Finally, a seafood place that takes allergies seriously! The gluten-free fried shrimp was amazing. My daughter with celiac could eat safely. We'll be regulars."
          </p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-brand-gold/20 rounded-full flex items-center justify-center text-brand-gold font-bold text-sm">S</div>
            <div>
              <p class="font-bold text-sm">Sarah T.</p>
              <p class="text-white/40 text-xs">Google Review</p>
            </div>
          </div>
        </div>

        <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-8 card-hover animate-on-scroll delay-3">
          <div class="flex gap-1 mb-4">
            <span class="star-gold">&#9733;</span><span class="star-gold">&#9733;</span><span class="star-gold">&#9733;</span><span class="star-gold">&#9733;</span><span class="star-gold">&#9733;</span>
          </div>
          <p class="text-white/80 leading-relaxed mb-6 italic">
            "The rum punch alone is worth the trip. Great food, awesome vibe, and they let us bring our dog on the patio. Perfect Florida evening."
          </p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-brand-gold/20 rounded-full flex items-center justify-center text-brand-gold font-bold text-sm">J</div>
            <div>
              <p class="font-bold text-sm">James L.</p>
              <p class="text-white/40 text-xs">TripAdvisor Review</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Hours & Location -->
  <section class="py-24 md:py-32 bg-brand-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="animate-on-scroll">
          <p class="text-brand-red font-bold text-sm tracking-[0.3em] uppercase mb-4">Visit Us</p>
          <h2 class="section-heading mb-8">Come Hungry,<br />Leave Happy</h2>

          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-14 h-14 bg-brand-blue rounded-2xl flex items-center justify-center flex-shrink-0 shadow-lg">
                <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-display text-xl font-bold text-brand-navy">Open Daily</h3>
                <p class="text-gray-600 text-lg">11:00 AM – 8:30 PM</p>
                <p class="text-gray-400 text-sm mt-1">Seven days a week</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-14 h-14 bg-brand-blue rounded-2xl flex items-center justify-center flex-shrink-0 shadow-lg">
                <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-display text-xl font-bold text-brand-navy">Fort Myers</h3>
                <p class="text-gray-600">15271 McGregor Blvd, Suite 1</p>
                <p class="text-gray-600">Fort Myers, Florida 33908</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-14 h-14 bg-brand-blue rounded-2xl flex items-center justify-center flex-shrink-0 shadow-lg">
                <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <h3 class="font-display text-xl font-bold text-brand-navy">Call Ahead</h3>
                <p class="text-gray-600">
                  <a href="tel:+12394827272" class="text-brand-blue hover:text-brand-red transition-colors text-lg font-semibold">(239) 482-7272</a>
                </p>
              </div>
            </div>
          </div>

          <div class="mt-10">
            <a href="/contact" class="btn-primary">Get Directions</a>
          </div>
        </div>

        <!-- Map / Image -->
        <div class="animate-on-scroll">
          <div class="rounded-2xl overflow-hidden shadow-2xl">
            <img
              src="https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=800&q=80"
              alt="Warm restaurant interior with ambient lighting"
              class="w-full h-[400px] lg:h-[500px] object-cover"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="relative py-24 md:py-32 overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1504674900247-0877df9cc836?w=1920&q=80"
        alt="Beautifully plated seafood dish"
        class="w-full h-full object-cover"
        loading="lazy"
      />
      <div class="absolute inset-0 overlay-dark"></div>
    </div>
    <div class="relative max-w-3xl mx-auto px-4 text-center text-white animate-on-scroll">
      <h2 class="font-display text-3xl md:text-5xl font-bold mb-6">Ready to Taste<br />the Gulf Coast?</h2>
      <p class="text-white/80 text-lg md:text-xl mb-10 max-w-xl mx-auto">
        Fresh seafood, bold Cajun flavors, and the best shrimp in Fort Myers. Your table is waiting.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/menu" class="btn-gold text-base px-12 py-5">Explore the Menu</a>
        <a href="tel:+12394827272" class="btn-outline text-base px-12 py-5">Call Now</a>
      </div>
    </div>
  </section>
</Layout>
