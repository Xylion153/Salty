---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
  <!-- Hero with warm food imagery -->
  <section class="relative overflow-hidden bg-brand-navy">
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=1920&q=80"
        alt="Warm restaurant dining"
        class="w-full h-full object-cover opacity-25"
        loading="eager"
      />
    </div>
    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-36 text-center text-white">
      <div class="mb-6 animate-fade-in">
        <img
          src="/logo.png"
          alt="Salty Papa's Shrimp House logo"
          class="h-28 md:h-40 w-auto mx-auto drop-shadow-md"
          onerror="this.style.display='none'"
        />
      </div>
      <h1 class="font-display text-4xl md:text-5xl font-bold mb-3 animate-fade-in">
        Salty Papa's Shrimp House
      </h1>
      <p class="text-brand-gold text-lg md:text-xl mb-2 animate-fade-in">
        Where the Bayou Meets the Beach
      </p>
      <p class="text-white/50 mb-10 animate-fade-in">
        Fort Myers, Florida &bull; Open Daily 11am – 8:30pm
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center animate-fade-in">
        <a href="/menu" class="btn-primary px-8 py-3.5">See Our Menu</a>
        <a href="tel:+12394827272" class="btn-outline px-8 py-3.5">Call (239) 482-7272</a>
      </div>
    </div>
  </section>

  <!-- Welcome -->
  <section class="bg-brand-cream py-16 md:py-20">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display text-2xl md:text-3xl font-bold text-brand-navy mb-5 animate-on-scroll">
        Come On In, Y'all
      </h2>
      <p class="text-gray-600 leading-relaxed mb-4 animate-on-scroll">
        Everything on our menu is sourced from Florida and the South and made from scratch
        right here in our kitchen. Our two amazing chefs bring you the rich, spicy flavors of the
        bayou alongside the fresh, light tastes of the Gulf Coast.
      </p>
      <p class="text-gray-600 leading-relaxed animate-on-scroll">
        We're a neighborhood spot — come as you are, bring the family (and the dog!),
        and enjoy yourself for a spell.
      </p>
      <div class="divider-gold mx-auto mt-6 animate-on-scroll"></div>
    </div>
  </section>

  <!-- Fan Favorites — dishes that pop in as you scroll -->
  <section class="py-16 md:py-20 bg-white overflow-hidden">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display text-2xl md:text-3xl font-bold text-brand-navy text-center mb-12 animate-on-scroll">
        Fan Favorites
      </h2>

      <!-- Dish 1: left image -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center mb-14">
        <div class="dish-slide-left rounded-xl overflow-hidden shadow-md">
          <img src="https://images.unsplash.com/photo-1615141982883-c7ad0e69fd62?w=700&q=80" alt="Shrimp and Grits" class="w-full h-56 md:h-64 object-cover" loading="lazy" />
        </div>
        <div class="dish-slide-right">
          <p class="text-brand-red text-xs font-semibold tracking-wider uppercase mb-1">Signature Dish</p>
          <h3 class="font-display text-xl font-bold text-brand-navy mb-2">Papa's Famous Shrimp &amp; Grits</h3>
          <p class="text-gray-500 leading-relaxed text-sm">
            Creamy cheddar cheese grits topped with sautéed pink Gulf shrimp, spicy andouille sausage,
            white wine, peppers, and our signature Low Country seasonings. The dish that put us on the map.
          </p>
          <p class="text-brand-red font-display font-bold text-lg mt-3">$24.99</p>
        </div>
      </div>

      <!-- Dish 2: right image -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center mb-14">
        <div class="dish-slide-left md:order-2 rounded-xl overflow-hidden shadow-md">
          <img src="https://images.unsplash.com/photo-1568901346375-23c9450c58cd?w=700&q=80" alt="Black Angus Burger" class="w-full h-56 md:h-64 object-cover" loading="lazy" />
        </div>
        <div class="dish-slide-right md:order-1">
          <p class="text-brand-red text-xs font-semibold tracking-wider uppercase mb-1">Crowd Pleaser</p>
          <h3 class="font-display text-xl font-bold text-brand-navy mb-2">Black Angus Steak Burger</h3>
          <p class="text-gray-500 leading-relaxed text-sm">
            No wimpy fast food patty! A thick 1/2 pound of fresh beef, grilled to order on bakery brioche
            with lettuce, tomato, pickles, and red onion. Even a simple lunch tastes great here.
          </p>
          <p class="text-brand-red font-display font-bold text-lg mt-3">$14.99</p>
        </div>
      </div>

      <!-- Dish 3: left image -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center mb-14">
        <div class="dish-slide-left rounded-xl overflow-hidden shadow-md">
          <img src="https://images.unsplash.com/photo-1551024709-8f23befc6f87?w=700&q=80" alt="Salty Papa Margarita" class="w-full h-56 md:h-64 object-cover" loading="lazy" />
        </div>
        <div class="dish-slide-right">
          <p class="text-brand-red text-xs font-semibold tracking-wider uppercase mb-1">Signature Drink</p>
          <h3 class="font-display text-xl font-bold text-brand-navy mb-2">The Salty Papa Margarita</h3>
          <p class="text-gray-500 leading-relaxed text-sm">
            Premium tequila and orange liqueur blended with real lime, lemon, and orange juices.
            On the rocks or frozen — traditional, strawberry, or mango. The perfect Gulf Coast sipper.
          </p>
          <p class="text-brand-red font-display font-bold text-lg mt-3">$9.99</p>
        </div>
      </div>

      <!-- Dish 4: right image -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
        <div class="dish-slide-left md:order-2 rounded-xl overflow-hidden shadow-md">
          <img src="https://images.unsplash.com/photo-1599487488170-d11ec9c172f0?w=700&q=80" alt="Cajun Calamari" class="w-full h-56 md:h-64 object-cover" loading="lazy" />
        </div>
        <div class="dish-slide-right md:order-1">
          <p class="text-brand-red text-xs font-semibold tracking-wider uppercase mb-1">Starter</p>
          <h3 class="font-display text-xl font-bold text-brand-navy mb-2">Louisiana Gator Tail</h3>
          <p class="text-gray-500 leading-relaxed text-sm">
            Bite-sized pieces of real gator marinated, lightly-floured and fried, served with our
            Cajun remoulade. A southern classic you won't find just anywhere.
          </p>
          <p class="text-brand-red font-display font-bold text-lg mt-3">$16.99</p>
        </div>
      </div>

      <div class="text-center mt-12 animate-on-scroll">
        <a href="/menu" class="btn-primary px-8 py-3.5">See Full Menu</a>
      </div>
    </div>
  </section>

  <!-- What We're Known For -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display text-2xl md:text-3xl font-bold text-brand-navy text-center mb-10 animate-on-scroll">
        What We're Known For
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <a href="/menu#signature-shrimp-dishes" class="group rounded-xl overflow-hidden shadow-md hover:shadow-lg transition-shadow bg-white animate-on-scroll delay-1">
          <div class="img-zoom h-52">
            <img src="https://images.unsplash.com/photo-1615141982883-c7ad0e69fd62?w=600&q=80" alt="Fresh Gulf shrimp" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div class="p-5">
            <h3 class="font-display text-lg font-bold text-brand-navy mb-1.5 group-hover:text-brand-red transition-colors">Fresh Gulf Seafood</h3>
            <p class="text-gray-500 text-sm leading-relaxed">
              Real USA wild-caught shrimp, grouper, oysters, stone crab, and today's catch —
              straight from Gulf fishermen. Never imported.
            </p>
            <span class="text-brand-red text-sm font-semibold mt-3 inline-block group-hover:translate-x-1 transition-transform">See menu &rarr;</span>
          </div>
        </a>

        <a href="/menu#chicken---beef-entrees" class="group rounded-xl overflow-hidden shadow-md hover:shadow-lg transition-shadow bg-white animate-on-scroll delay-2">
          <div class="img-zoom h-52">
            <img src="https://images.unsplash.com/photo-1626645738196-c2a7c87a8f58?w=600&q=80" alt="Southern comfort food" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div class="p-5">
            <h3 class="font-display text-lg font-bold text-brand-navy mb-1.5 group-hover:text-brand-red transition-colors">Southern Comfort Food</h3>
            <p class="text-gray-500 text-sm leading-relaxed">
              Shrimp &amp; grits, gumbo, jambalaya, fried green tomatoes, chicken &amp; waffles,
              po' boys — food that makes you feel at home.
            </p>
            <span class="text-brand-red text-sm font-semibold mt-3 inline-block group-hover:translate-x-1 transition-transform">See menu &rarr;</span>
          </div>
        </a>

        <a href="/menu#papa-s-signature-drinks" class="group rounded-xl overflow-hidden shadow-md hover:shadow-lg transition-shadow bg-white animate-on-scroll delay-3">
          <div class="img-zoom h-52">
            <img src="https://images.unsplash.com/photo-1551024709-8f23befc6f87?w=600&q=80" alt="Tropical drinks" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div class="p-5">
            <h3 class="font-display text-lg font-bold text-brand-navy mb-1.5 group-hover:text-brand-red transition-colors">Local Drinks &amp; Craft Beer</h3>
            <p class="text-gray-500 text-sm leading-relaxed">
              Wicked Dolphin rum from Cape Coral, Cigar City brews from Tampa,
              11 signature cocktails, and fresh-squeezed lemonades.
            </p>
            <span class="text-brand-red text-sm font-semibold mt-3 inline-block group-hover:translate-x-1 transition-transform">See drinks &rarr;</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Red accent band -->
  <section class="bg-brand-red text-white py-10">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div class="animate-on-scroll delay-1">
          <p class="font-display text-2xl font-bold">100%</p>
          <p class="text-white/70 text-xs mt-0.5">Scratch-Made</p>
        </div>
        <div class="animate-on-scroll delay-2">
          <p class="font-display text-2xl font-bold">GF Fryers</p>
          <p class="text-white/70 text-xs mt-0.5">Allergy Friendly</p>
        </div>
        <div class="animate-on-scroll delay-3">
          <p class="font-display text-2xl font-bold">Pup Menu</p>
          <p class="text-white/70 text-xs mt-0.5">Pet-Friendly Patio</p>
        </div>
        <div class="animate-on-scroll delay-4">
          <p class="font-display text-2xl font-bold">5 Stars</p>
          <p class="text-white/70 text-xs mt-0.5">Yelp &bull; TripAdvisor</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why folks come back — side by side -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div class="grid grid-cols-2 gap-3 animate-on-scroll">
          <div class="rounded-xl overflow-hidden">
            <img src="https://images.unsplash.com/photo-1559339352-11d035aa65de?w=400&q=80" alt="Chef preparing food" class="w-full h-40 md:h-52 object-cover" loading="lazy" />
          </div>
          <div class="rounded-xl overflow-hidden mt-6">
            <img src="https://images.unsplash.com/photo-1590759668628-05b0fc34bb70?w=400&q=80" alt="Seafood platter" class="w-full h-40 md:h-52 object-cover" loading="lazy" />
          </div>
          <div class="rounded-xl overflow-hidden">
            <img src="https://images.unsplash.com/photo-1587300003388-59208cc962cb?w=400&q=80" alt="Dog on patio" class="w-full h-40 md:h-52 object-cover" loading="lazy" />
          </div>
          <div class="rounded-xl overflow-hidden mt-6">
            <img src="https://images.unsplash.com/photo-1533777857889-4be7c70b33f7?w=400&q=80" alt="Patio dining" class="w-full h-40 md:h-52 object-cover" loading="lazy" />
          </div>
        </div>

        <div class="animate-on-scroll">
          <h2 class="font-display text-2xl md:text-3xl font-bold text-brand-navy mb-5">
            Why Folks Keep Coming Back
          </h2>
          <ul class="space-y-3.5 text-gray-600">
            <li class="flex gap-3 items-start">
              <span class="w-6 h-6 bg-brand-red/10 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                <span class="text-brand-red text-xs font-bold">&#10003;</span>
              </span>
              <span><strong>Allergy friendly</strong> — dedicated gluten-free fryers, staff trained on every ingredient</span>
            </li>
            <li class="flex gap-3 items-start">
              <span class="w-6 h-6 bg-brand-red/10 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                <span class="text-brand-red text-xs font-bold">&#10003;</span>
              </span>
              <span><strong>Pet-friendly courtyard</strong> — bring the pup, we've got a Pupper Meals menu for them</span>
            </li>
            <li class="flex gap-3 items-start">
              <span class="w-6 h-6 bg-brand-red/10 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                <span class="text-brand-red text-xs font-bold">&#10003;</span>
              </span>
              <span><strong>Everything homemade</strong> — sauces, dressings, soups, desserts, all from scratch daily</span>
            </li>
            <li class="flex gap-3 items-start">
              <span class="w-6 h-6 bg-brand-red/10 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                <span class="text-brand-red text-xs font-bold">&#10003;</span>
              </span>
              <span><strong>Never imported seafood</strong> — only USA-sourced from Florida, Texas, and Louisiana fishermen</span>
            </li>
            <li class="flex gap-3 items-start">
              <span class="w-6 h-6 bg-brand-red/10 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                <span class="text-brand-red text-xs font-bold">&#10003;</span>
              </span>
              <span><strong>Owner always on-site</strong> — any request or concern, handled right on the spot</span>
            </li>
          </ul>
          <a href="/about" class="inline-block mt-6 text-brand-red font-semibold text-sm hover:text-red-700 transition-colors">
            Read our full story &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Reviews -->
  <section class="bg-brand-cream py-16 md:py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display text-2xl md:text-3xl font-bold text-brand-navy text-center mb-10 animate-on-scroll">
        What People Are Saying
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        <div class="bg-white rounded-xl p-6 shadow-sm animate-on-scroll delay-1">
          <div class="flex gap-0.5 mb-3 text-yellow-500">
            <span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span>&#9733;</span>
          </div>
          <p class="text-gray-600 leading-relaxed mb-4 italic text-sm">
            "Best shrimp &amp; grits I've ever had outside of New Orleans. The andouille cream sauce is incredible. Hidden gem on McGregor!"
          </p>
          <p class="text-sm font-semibold text-brand-navy">Mike R. <span class="font-normal text-gray-400">— Yelp</span></p>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-sm animate-on-scroll delay-2">
          <div class="flex gap-0.5 mb-3 text-yellow-500">
            <span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span>&#9733;</span>
          </div>
          <p class="text-gray-600 leading-relaxed mb-4 italic text-sm">
            "Finally a seafood place that takes allergies seriously! My daughter with celiac could eat safely. We'll be regulars."
          </p>
          <p class="text-sm font-semibold text-brand-navy">Sarah T. <span class="font-normal text-gray-400">— Google</span></p>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-sm animate-on-scroll delay-3">
          <div class="flex gap-0.5 mb-3 text-yellow-500">
            <span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span>&#9733;</span>
          </div>
          <p class="text-gray-600 leading-relaxed mb-4 italic text-sm">
            "The rum punch alone is worth the trip. Great food, awesome vibe, and they let us bring our dog on the patio. Perfect Florida evening."
          </p>
          <p class="text-sm font-semibold text-brand-navy">James L. <span class="font-normal text-gray-400">— TripAdvisor</span></p>
        </div>
      </div>
    </div>
  </section>

  <!-- Visit CTA with image -->
  <section class="relative overflow-hidden bg-brand-navy text-white">
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=1920&q=80"
        alt="Restaurant interior"
        class="w-full h-full object-cover opacity-20"
        loading="lazy"
      />
    </div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center mb-10">
        <div class="animate-on-scroll">
          <h3 class="text-brand-gold font-display font-bold mb-1">Hours</h3>
          <p class="text-white/80">Open Daily</p>
          <p class="text-white font-semibold text-lg">11am – 8:30pm</p>
        </div>
        <div class="animate-on-scroll">
          <h3 class="text-brand-gold font-display font-bold mb-1">Location</h3>
          <p class="text-white/80">15271 McGregor Blvd, Suite 1</p>
          <p class="text-white/80">Fort Myers, FL 33908</p>
        </div>
        <div class="animate-on-scroll">
          <h3 class="text-brand-gold font-display font-bold mb-1">Phone</h3>
          <a href="tel:+12394827272" class="text-white font-semibold text-lg hover:text-brand-gold transition-colors">(239) 482-7272</a>
        </div>
      </div>
      <div class="text-center animate-on-scroll">
        <a href="/contact" class="btn-primary bg-brand-red px-8 py-3.5">Get Directions</a>
      </div>
    </div>
  </section>
</Layout>
