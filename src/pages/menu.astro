---
import Layout from '../layouts/Layout.astro';
import menuData from '../data/menu.json';
---

<Layout title="Menu" description="Explore the full menu at Salty Papa's Shrimp House — fresh Gulf seafood, po'boys, Cajun classics, and more.">
  <!-- Hero -->
  <section class="relative overflow-hidden bg-brand-navy">
    <div class="absolute inset-0">
      <img src="https://images.unsplash.com/photo-1504674900247-0877df9cc836?w=1920&q=80" alt="Food spread" class="w-full h-full object-cover opacity-20" loading="eager" />
    </div>
    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28 text-center text-white">
      <p class="text-brand-gold text-sm tracking-wider font-semibold mb-3 animate-fade-in">Fresh from the Gulf</p>
      <h1 class="font-display text-4xl md:text-5xl font-bold mb-3 animate-fade-in">Our Menu</h1>
      <p class="text-white/60 max-w-xl mx-auto animate-fade-in">
        Proudly serving genuine USA wild-caught Gulf shrimp, never imported.
        Everything made from scratch, every single day.
      </p>
    </div>
  </section>

  <!-- Category Nav -->
  <nav aria-label="Menu categories" class="bg-brand-cream sticky top-16 z-30 border-b border-brand-sand shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <ul class="flex gap-6 overflow-x-auto py-4 text-sm font-bold" role="list" id="menu-nav">
        {menuData.categories.map(cat => (
          <li class="flex-shrink-0">
            <a
              href={`#${cat.name.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`}
              class="menu-nav-link text-gray-400 hover:text-brand-red transition-colors whitespace-nowrap tracking-wider pb-2 border-b-2 border-transparent hover:border-brand-red"
              data-section={cat.name.toLowerCase().replace(/[^a-z0-9]+/g, '-')}
            >
              {cat.name}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>

  <!-- Menu Sections -->
  <div class="bg-brand-warm py-16 md:py-24">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 space-y-24">
      {menuData.categories.map((category) => (
        <section id={category.name.toLowerCase().replace(/[^a-z0-9]+/g, '-')} class="scroll-mt-28">
          <div class="grid grid-cols-1 md:grid-cols-[260px_1fr] gap-8 md:gap-12 animate-on-scroll">
            <!-- Category image & heading -->
            <div class="md:sticky md:top-28 md:self-start">
              {category.image && (
                <div class="img-zoom rounded-2xl overflow-hidden shadow-lg">
                  <img
                    src={category.image}
                    alt={category.name}
                    class="w-full h-44 md:h-56 object-cover"
                    loading="lazy"
                  />
                </div>
              )}
              <h2 class="font-display text-2xl md:text-3xl font-bold text-brand-navy mt-5 mb-2">{category.name}</h2>
              <p class="text-gray-400 text-sm leading-relaxed">{category.description}</p>
              <div class="divider-gold mt-4"></div>
            </div>

            <!-- Items -->
            <div>
              <ul class="space-y-1" role="list">
                {category.items.map((item) => (
                  <li class="group py-5 px-5 rounded-xl hover:bg-white hover:shadow-sm transition-all duration-300">
                    <div class="flex justify-between items-start gap-4">
                      <div class="flex-1">
                        <h3 class="font-display text-lg font-bold text-brand-navy group-hover:text-brand-red transition-colors">
                          {item.name}
                        </h3>
                        <p class="text-gray-500 text-sm mt-1.5 leading-relaxed">
                          {item.description}
                        </p>
                        {item.note && (
                          <p class="text-brand-blue text-xs font-semibold mt-1 italic">{item.note}</p>
                        )}
                      </div>
                      <div class="flex-shrink-0 pt-0.5">
                        <span class="text-brand-red font-display font-bold text-lg whitespace-nowrap">
                          {item.price === 'Market Price'
                            ? 'MKT'
                            : item.price.includes('/')
                              ? `$${item.price}`
                              : `$${item.price}`}
                        </span>
                      </div>
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </section>
      ))}
    </div>
  </div>

  <!-- Bottom Note -->
  <section class="bg-brand-navy text-white py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="flex justify-center gap-2 mb-4 items-center">
        <svg class="w-5 h-5 text-brand-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
        </svg>
        <span class="text-brand-gold font-bold text-sm uppercase tracking-wider">Allergy Notice</span>
      </div>
      <p class="text-white/60 text-sm">
        Please inform your server of any food allergies. We maintain dedicated gluten-free and seafood-only deep fryers.
        Our wait staff is educated on all ingredients to ensure a pleasant experience for diners sensitive to allergens.
      </p>
      <p class="text-white/40 text-xs mt-3">
        Use care when eating oysters, crab and other shellfish as they may have shell particles present.
        Consuming raw or undercooked meats, poultry, seafood, shellfish or eggs may increase your risk of foodborne illness.
      </p>
      <div class="mt-8 pt-8 border-t border-white/10">
        <p class="text-white/50 text-sm">
          Our dips, sauces, dressings, and butter sauces are all homemade. Additional sauce cups: Small $.50 / Large $1.00
        </p>
      </div>
    </div>
  </section>
</Layout>

<script>
  const sections = document.querySelectorAll('section[id]');
  const navLinks = document.querySelectorAll('.menu-nav-link');

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          navLinks.forEach((link) => {
            const el = link as HTMLElement;
            if (el.dataset.section === id) {
              el.classList.add('text-brand-red', 'border-brand-red');
              el.classList.remove('text-gray-400', 'border-transparent');
            } else {
              el.classList.remove('text-brand-red', 'border-brand-red');
              el.classList.add('text-gray-400', 'border-transparent');
            }
          });
        }
      });
    },
    { threshold: 0.2, rootMargin: '-100px 0px -50% 0px' }
  );

  sections.forEach((section) => observer.observe(section));
</script>
