---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Find Salty Papa's Shrimp House in Fort Myers, FL. Get directions, hours, and contact info.">
  <!-- Page Header -->
  <section class="bg-brand-navy text-white py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-brand-gold text-sm tracking-[0.3em] uppercase font-semibold mb-4">
        Come Say Hello
      </p>
      <h1 class="font-display text-4xl md:text-6xl font-extrabold mb-4">Contact Us</h1>
      <p class="text-white/70 text-lg max-w-xl mx-auto">
        We'd love to see you. Stop by, give us a call, or drop us a line.
      </p>
    </div>
  </section>

  <!-- Contact Grid -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">
        <!-- Info -->
        <div>
          <h2 class="section-heading mb-8">Get in Touch</h2>

          <div class="space-y-8">
            <!-- Address -->
            <div class="flex gap-4">
              <div class="w-12 h-12 bg-brand-cream rounded-full flex items-center justify-center flex-shrink-0" aria-hidden="true">
                <svg class="w-6 h-6 text-brand-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-display text-lg font-bold text-brand-navy mb-1">Address</h3>
                <address class="not-italic text-gray-600 leading-relaxed">
                  15271 McGregor Blvd, Suite 1<br />
                  Fort Myers, Florida 33908
                </address>
                <a
                  href="https://maps.google.com/?q=15271+McGregor+Blvd+Suite+1+Fort+Myers+FL+33908"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-block mt-2 text-sm font-semibold text-brand-red hover:text-red-700 transition-colors"
                >
                  Get Directions &rarr;
                </a>
              </div>
            </div>

            <!-- Phone -->
            <div class="flex gap-4">
              <div class="w-12 h-12 bg-brand-cream rounded-full flex items-center justify-center flex-shrink-0" aria-hidden="true">
                <svg class="w-6 h-6 text-brand-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <h3 class="font-display text-lg font-bold text-brand-navy mb-1">Phone</h3>
                <a href="tel:+12394827272" class="text-gray-600 hover:text-brand-red transition-colors">
                  (239) 482-7272
                </a>
              </div>
            </div>

            <!-- Email -->
            <div class="flex gap-4">
              <div class="w-12 h-12 bg-brand-cream rounded-full flex items-center justify-center flex-shrink-0" aria-hidden="true">
                <svg class="w-6 h-6 text-brand-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <h3 class="font-display text-lg font-bold text-brand-navy mb-1">Email</h3>
                <a href="mailto:info@SaltyPapasShrimpHouse.com" class="text-gray-600 hover:text-brand-red transition-colors">
                  info@SaltyPapasShrimpHouse.com
                </a>
              </div>
            </div>

            <!-- Hours -->
            <div class="flex gap-4">
              <div class="w-12 h-12 bg-brand-cream rounded-full flex items-center justify-center flex-shrink-0" aria-hidden="true">
                <svg class="w-6 h-6 text-brand-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-display text-lg font-bold text-brand-navy mb-1">Hours</h3>
                <p class="text-gray-600">Open Daily: 11:00 AM – 8:30 PM</p>
                <p class="text-sm text-gray-400 mt-1">Seating ends at 8:30 PM</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Map Placeholder -->
        <div>
          <div class="aspect-square lg:aspect-[4/3] rounded-lg overflow-hidden bg-gray-100">
            <iframe
              title="Salty Papa's Shrimp House location map"
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3578.5!2d-81.9!3d26.56!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2s15271+McGregor+Blvd+Fort+Myers+FL!5e0!3m2!1sen!2sus!4v1"
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              class="w-full h-full"
            ></iframe>
          </div>
          <p class="text-sm text-gray-400 mt-3 text-center">
            Located on McGregor Blvd, just south of Colonial Blvd in Fort Myers
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-brand-cream py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display text-2xl md:text-3xl font-bold text-brand-navy mb-4">
        Hungry Yet?
      </h2>
      <p class="text-gray-600 text-lg mb-8">
        Check out our menu before you visit — from fresh Gulf shrimp to craft cocktails.
      </p>
      <a href="/menu" class="btn-primary">View the Menu</a>
    </div>
  </section>
</Layout>
