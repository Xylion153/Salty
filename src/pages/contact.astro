---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Find Salty Papa's Shrimp House in Fort Myers, FL. Get directions, hours, and contact info.">
  <!-- Hero -->
  <section class="relative py-32 md:py-40 overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=1920&q=80"
        alt="Restaurant interior with warm lighting"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 overlay-dark"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-white">
      <p class="text-brand-gold text-sm tracking-[0.4em] uppercase font-bold mb-6 animate-fade-in">
        Come Say Hello
      </p>
      <h1 class="font-display text-5xl md:text-7xl font-black mb-6 animate-fade-in">Contact Us</h1>
      <p class="text-white/70 text-lg md:text-xl max-w-xl mx-auto animate-fade-in">
        We'd love to see you. Stop by, give us a call, or drop us a line.
      </p>
    </div>
  </section>

  <!-- Contact Grid -->
  <section class="py-24 md:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
        <!-- Info Cards -->
        <div class="animate-on-scroll">
          <p class="text-brand-red font-bold text-sm tracking-[0.3em] uppercase mb-4">Get in Touch</p>
          <h2 class="section-heading mb-10">We're Here<br />For You</h2>

          <div class="space-y-6">
            <!-- Address Card -->
            <a
              href="https://maps.google.com/?q=15271+McGregor+Blvd+Suite+1+Fort+Myers+FL+33908"
              target="_blank"
              rel="noopener noreferrer"
              class="flex gap-5 p-6 rounded-2xl bg-brand-cream hover:bg-brand-sand transition-all duration-300 hover:shadow-md group"
            >
              <div class="w-14 h-14 bg-brand-blue rounded-2xl flex items-center justify-center flex-shrink-0 shadow-lg group-hover:scale-110 transition-transform">
                <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-display text-lg font-bold text-brand-navy mb-1">Address</h3>
                <p class="text-gray-600">15271 McGregor Blvd, Suite 1</p>
                <p class="text-gray-600">Fort Myers, Florida 33908</p>
                <p class="text-brand-red font-bold text-sm mt-2 group-hover:translate-x-1 transition-transform">
                  Get Directions &rarr;
                </p>
              </div>
            </a>

            <!-- Phone Card -->
            <a
              href="tel:+12394827272"
              class="flex gap-5 p-6 rounded-2xl bg-brand-cream hover:bg-brand-sand transition-all duration-300 hover:shadow-md group"
            >
              <div class="w-14 h-14 bg-brand-red rounded-2xl flex items-center justify-center flex-shrink-0 shadow-lg group-hover:scale-110 transition-transform">
                <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <h3 class="font-display text-lg font-bold text-brand-navy mb-1">Phone</h3>
                <p class="text-gray-600 text-lg">(239) 482-7272</p>
                <p class="text-brand-red font-bold text-sm mt-2 group-hover:translate-x-1 transition-transform">
                  Call Now &rarr;
                </p>
              </div>
            </a>

            <!-- Email Card -->
            <a
              href="mailto:info@SaltyPapasShrimpHouse.com"
              class="flex gap-5 p-6 rounded-2xl bg-brand-cream hover:bg-brand-sand transition-all duration-300 hover:shadow-md group"
            >
              <div class="w-14 h-14 bg-brand-gold rounded-2xl flex items-center justify-center flex-shrink-0 shadow-lg group-hover:scale-110 transition-transform">
                <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <h3 class="font-display text-lg font-bold text-brand-navy mb-1">Email</h3>
                <p class="text-gray-600">info@SaltyPapasShrimpHouse.com</p>
                <p class="text-brand-red font-bold text-sm mt-2 group-hover:translate-x-1 transition-transform">
                  Send Email &rarr;
                </p>
              </div>
            </a>

            <!-- Hours Card -->
            <div class="flex gap-5 p-6 rounded-2xl bg-brand-navy text-white">
              <div class="w-14 h-14 bg-white/10 rounded-2xl flex items-center justify-center flex-shrink-0">
                <svg class="w-7 h-7 text-brand-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-display text-lg font-bold mb-1">Hours</h3>
                <p class="text-white/80 text-lg">Open Daily: 11:00 AM – 8:30 PM</p>
                <p class="text-white/40 text-sm mt-1">Seating ends at 8:30 PM</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Map -->
        <div class="animate-on-scroll">
          <div class="rounded-2xl overflow-hidden shadow-2xl h-full min-h-[500px]">
            <iframe
              title="Salty Papa's Shrimp House location map"
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3578.5!2d-81.9!3d26.56!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2s15271+McGregor+Blvd+Fort+Myers+FL!5e0!3m2!1sen!2sus!4v1"
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              class="w-full h-full min-h-[500px]"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Social -->
  <section class="bg-brand-cream py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center animate-on-scroll">
      <p class="text-brand-red font-bold text-sm tracking-[0.3em] uppercase mb-4">Follow Along</p>
      <h2 class="font-display text-2xl md:text-3xl font-bold text-brand-navy mb-8">Find Us on Social</h2>
      <div class="flex justify-center gap-6">
        <a
          href="https://www.facebook.com/saltypapasshrimphouse"
          target="_blank"
          rel="noopener noreferrer"
          class="w-14 h-14 bg-brand-navy rounded-2xl flex items-center justify-center text-white hover:bg-brand-blue hover:scale-110 transition-all duration-300 shadow-lg"
          aria-label="Visit us on Facebook"
        >
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
          </svg>
        </a>
        <a
          href="https://www.yelp.com/biz/salty-papas-shrimp-house-fort-myers"
          target="_blank"
          rel="noopener noreferrer"
          class="w-14 h-14 bg-brand-navy rounded-2xl flex items-center justify-center text-white hover:bg-brand-red hover:scale-110 transition-all duration-300 shadow-lg"
          aria-label="Find us on Yelp"
        >
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-brand-navy text-white py-20">
    <div class="max-w-3xl mx-auto px-4 text-center animate-on-scroll">
      <h2 class="font-display text-3xl md:text-4xl font-bold mb-4">
        Hungry Yet?
      </h2>
      <p class="text-white/70 text-lg mb-8">
        Check out our menu before you visit — from fresh Gulf shrimp to craft cocktails.
      </p>
      <a href="/menu" class="btn-gold">View the Menu</a>
    </div>
  </section>
</Layout>
