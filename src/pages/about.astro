---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About" description="Learn about Salty Papa's Shrimp House — our story, our chefs, and our commitment to fresh Gulf seafood in Fort Myers.">
  <!-- Hero -->
  <section class="bg-brand-navy py-24 md:py-32">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-white">
      <p class="text-brand-gold text-sm tracking-[0.3em] uppercase font-bold mb-4 animate-fade-in">Our Story</p>
      <h1 class="font-display text-4xl md:text-5xl font-bold mb-4 animate-fade-in">About Us</h1>
      <p class="text-white/60 text-lg max-w-xl mx-auto animate-fade-in">
        Where the Bayou Meets the Beach... Everyday!
      </p>
    </div>
  </section>

  <!-- Their Story -->
  <section class="py-24 md:py-32 bg-brand-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
        <!-- Image -->
        <div class="animate-on-scroll">
          <div class="relative">
            <div class="img-zoom rounded-2xl overflow-hidden shadow-2xl">
              <img
                src="https://images.unsplash.com/photo-1577219491135-ce391730fb2c?w=800&q=80"
                alt="Chef at work in the kitchen"
                class="w-full h-[400px] lg:h-[550px] object-cover"
                loading="lazy"
              />
            </div>
            <div class="absolute -bottom-6 -right-6 bg-brand-red text-white rounded-2xl p-6 shadow-xl hidden md:block">
              <p class="font-display text-3xl font-black">Lifetime</p>
              <p class="text-sm font-bold tracking-wider uppercase">of Experience</p>
            </div>
          </div>
        </div>

        <!-- Text — Their actual story -->
        <div class="animate-on-scroll">
          <p class="text-brand-red font-bold text-sm tracking-[0.3em] uppercase mb-4">Welcome to Our Table</p>
          <h2 class="section-heading mb-8">Where the Bayou<br />Meets the Beach</h2>
          <div class="space-y-5 text-gray-600 leading-relaxed text-lg">
            <p>
              Every item on our menu showcases proteins and produce that can be cultivated and sourced from
              <strong>Florida and the South</strong>. Our homemade dishes feature rich and spicy foods found throughout
              the bayous and across all of Florida and the old South, along with the light and citrus-infused flavors
              found along the <strong>Gulf of Mexico</strong> coastlines.
            </p>
            <p>
              We extend our "Southernality" into our drink menu as well, with real fruit frozen drinks featuring
              <strong>Cape Coral's</strong> amazing <strong>Wicked Dolphin</strong> spiced honey rum, fresh fruit-infused
              martinis, homemade frozen lemonades, and our craft beer line featuring <strong>Cigar City Brewing</strong> ales
              made in Tampa, FL.
            </p>
            <p>
              All our <strong>fresh seafood</strong> comes from the Gulf waters brought to us from the
              <strong>fishermen of Florida, Texas and Louisiana</strong>, and if a shortage should occur we will only source
              US seafood — you will never find imported, chemical-coated shrimp in our kitchen!
            </p>
          </div>
          <div class="divider-gold mt-8"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Promise Section -->
  <section class="py-24 md:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
        <!-- Text -->
        <div class="order-2 lg:order-1 animate-on-scroll">
          <p class="text-brand-red font-bold text-sm tracking-[0.3em] uppercase mb-4">Our Promise to You</p>
          <h2 class="section-heading mb-8">You're Family<br />Here</h2>
          <div class="space-y-5 text-gray-600 leading-relaxed text-lg">
            <p>
              At Salty Papa's Shrimp House, you can count on us to always provide you authentic, fresh, homemade
              food served by a caring and professional staff. We will never compromise on quality, and our
              customers will <strong>always</strong> be right.
            </p>
            <p>
              Small details like <strong>gluten-free</strong> and seafood-only designated deep fryers, and a wait staff
              educated on ingredients will ensure a pleasant experience for diners sensitive to allergens.
            </p>
            <p>
              Backed by an owner with a <strong>lifetime of restaurant experience</strong> and two <strong>amazing chefs</strong>,
              the highest standards are always adhered to. The owner or manager on duty will always be available for any
              special request, and any problem can be corrected on the spot.
            </p>
            <p class="text-brand-navy font-semibold italic text-xl font-display">
              "When you come to Salty Papa's... we want you to feel at home, so stop on by and enjoy yourself for a spell."
            </p>
          </div>
        </div>

        <!-- Image -->
        <div class="order-1 lg:order-2 animate-on-scroll">
          <div class="grid grid-cols-2 gap-4">
            <div class="img-zoom rounded-2xl overflow-hidden shadow-lg">
              <img src="https://images.unsplash.com/photo-1559339352-11d035aa65de?w=400&q=80" alt="Chef preparing food with care" class="w-full h-48 md:h-64 object-cover" loading="lazy" />
            </div>
            <div class="img-zoom rounded-2xl overflow-hidden shadow-lg mt-8">
              <img src="https://images.unsplash.com/photo-1533777857889-4be7c70b33f7?w=400&q=80" alt="Patio dining at sunset" class="w-full h-48 md:h-64 object-cover" loading="lazy" />
            </div>
            <div class="img-zoom rounded-2xl overflow-hidden shadow-lg">
              <img src="https://images.unsplash.com/photo-1587300003388-59208cc962cb?w=400&q=80" alt="Dog-friendly patio" class="w-full h-48 md:h-64 object-cover" loading="lazy" />
            </div>
            <div class="img-zoom rounded-2xl overflow-hidden shadow-lg mt-8">
              <img src="https://images.unsplash.com/photo-1590759668628-05b0fc34bb70?w=400&q=80" alt="Fresh seafood spread" class="w-full h-48 md:h-64 object-cover" loading="lazy" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pet Friendly Callout -->
  <section class="bg-brand-navy py-14">
    <div class="max-w-3xl mx-auto px-4 text-center text-white animate-on-scroll">
      <h2 class="font-display text-2xl md:text-3xl font-bold mb-3">
        Bring Your Pup!
      </h2>
      <p class="text-white/70 text-lg">
        We've got a pet-friendly courtyard and a Pupper Meals menu for your four-legged friend.
        We love our fur family and can't wait to meet yours.
      </p>
    </div>
  </section>

  <!-- Values -->
  <section class="bg-white py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-brand-red font-bold text-sm tracking-[0.3em] uppercase mb-4 animate-on-scroll">What Matters to Us</p>
        <h2 class="section-heading animate-on-scroll">Our Values</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="bg-brand-cream rounded-2xl p-8 text-center card-hover animate-on-scroll delay-1">
          <div class="w-16 h-16 bg-brand-blue/10 rounded-full flex items-center justify-center mx-auto mb-5">
            <svg class="w-8 h-8 text-brand-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
            </svg>
          </div>
          <h3 class="font-display text-xl font-bold text-brand-navy mb-3">Always Fresh</h3>
          <p class="text-gray-500 text-sm leading-relaxed">
            USA-sourced Gulf seafood from Florida, Texas, and Louisiana fishermen. Never imported.
          </p>
        </div>

        <div class="bg-brand-cream rounded-2xl p-8 text-center card-hover animate-on-scroll delay-2">
          <div class="w-16 h-16 bg-brand-red/10 rounded-full flex items-center justify-center mx-auto mb-5">
            <svg class="w-8 h-8 text-brand-red" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z" />
            </svg>
          </div>
          <h3 class="font-display text-xl font-bold text-brand-navy mb-3">Scratch-Made</h3>
          <p class="text-gray-500 text-sm leading-relaxed">
            Every sauce, dressing, soup, and dessert is made from scratch right in our kitchen.
          </p>
        </div>

        <div class="bg-brand-cream rounded-2xl p-8 text-center card-hover animate-on-scroll delay-3">
          <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-5">
            <svg class="w-8 h-8 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
            </svg>
          </div>
          <h3 class="font-display text-xl font-bold text-brand-navy mb-3">Allergen Safe</h3>
          <p class="text-gray-500 text-sm leading-relaxed">
            Dedicated gluten-free fryers and a staff educated on every ingredient we use.
          </p>
        </div>

        <div class="bg-brand-cream rounded-2xl p-8 text-center card-hover animate-on-scroll delay-4">
          <div class="w-16 h-16 bg-brand-gold/10 rounded-full flex items-center justify-center mx-auto mb-5">
            <svg class="w-8 h-8 text-brand-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
            </svg>
          </div>
          <h3 class="font-display text-xl font-bold text-brand-navy mb-3">You're Family</h3>
          <p class="text-gray-500 text-sm leading-relaxed">
            Customer feedback drives us. The owner is always available. Your experience is our priority.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Awards -->
  <section class="bg-brand-navy text-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center animate-on-scroll">
      <p class="text-brand-gold font-bold text-sm tracking-[0.3em] uppercase mb-8">Recognized Excellence</p>
      <div class="flex flex-wrap justify-center gap-16 items-center">
        <div class="text-center">
          <div class="flex justify-center gap-1 mb-2">
            <span class="star-gold text-xl">&#9733;</span><span class="star-gold text-xl">&#9733;</span><span class="star-gold text-xl">&#9733;</span><span class="star-gold text-xl">&#9733;</span><span class="star-gold text-xl">&#9733;</span>
          </div>
          <p class="font-display text-2xl font-bold">5 Stars</p>
          <p class="text-white/50 text-sm mt-1">Yelp</p>
        </div>
        <div class="w-px h-16 bg-white/10" aria-hidden="true"></div>
        <div class="text-center">
          <p class="text-brand-gold text-3xl mb-2">&#127942;</p>
          <p class="font-display text-2xl font-bold">Travelers' Choice</p>
          <p class="text-white/50 text-sm mt-1">TripAdvisor 2025</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-brand-cream py-16 text-center">
    <div class="max-w-3xl mx-auto px-4 animate-on-scroll">
      <h2 class="font-display text-2xl md:text-3xl font-bold text-brand-navy mb-4">Come Hungry, Leave Happy</h2>
      <p class="text-gray-600 text-lg mb-8">
        Stop on by and enjoy yourself for a spell. We're open daily, 11am to 8:30pm.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/menu" class="btn-primary">See the Menu</a>
        <a href="/contact" class="btn-gold">Get Directions</a>
      </div>
    </div>
  </section>
</Layout>
