---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About" description="Learn about Salty Papa's Shrimp House — our story, our chefs, and our commitment to fresh Gulf seafood in Fort Myers.">
  <!-- Page Header -->
  <section class="bg-brand-navy text-white py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-brand-gold text-sm tracking-[0.3em] uppercase font-semibold mb-4">
        Our Story
      </p>
      <h1 class="font-display text-4xl md:text-6xl font-extrabold mb-4">About Us</h1>
      <p class="text-white/70 text-lg max-w-xl mx-auto">
        A love letter to Gulf Coast cuisine, built on experience, passion, and the freshest ingredients.
      </p>
    </div>
  </section>

  <!-- Story Section -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <!-- Image placeholder -->
        <div class="aspect-[4/3] rounded-lg overflow-hidden placeholder-img">
          <span>Image — Owner / Chef Portrait</span>
        </div>

        <!-- Text -->
        <div>
          <h2 class="section-heading mb-6">Where the Bayou<br />Meets the Beach</h2>
          <div class="space-y-4 text-gray-600 leading-relaxed">
            <p>
              Salty Papa's Shrimp House was born from a simple idea: bring the bold,
              soulful flavors of the bayou to the sunny shores of Fort Myers. Our owner
              brings decades of restaurant experience and an unwavering commitment to
              quality.
            </p>
            <p>
              We source our seafood from Florida and the South — Gulf shrimp, stone crab,
              fresh-caught grouper — and prepare everything from scratch. Our two professional
              chefs blend Cajun tradition with coastal creativity, creating dishes that are
              comforting, flavorful, and always fresh.
            </p>
            <p>
              Whether you're enjoying our signature shrimp &amp; grits, sipping a rum punch
              made with local Florida rum, or relaxing on our pet-friendly courtyard patio,
              we want you to feel right at home.
            </p>
          </div>
          <div class="w-12 h-px bg-brand-gold mt-8"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values / Highlights -->
  <section class="bg-brand-cream py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="section-heading mb-3">What We Stand For</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="w-14 h-14 bg-brand-blue rounded-full flex items-center justify-center mx-auto mb-4" aria-hidden="true">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
            </svg>
          </div>
          <h3 class="font-display text-lg font-bold text-brand-navy mb-2">Fresh Daily</h3>
          <p class="text-gray-600 text-sm">
            Seafood sourced from local Florida waters and the Gulf, never frozen.
          </p>
        </div>

        <div class="text-center">
          <div class="w-14 h-14 bg-brand-blue rounded-full flex items-center justify-center mx-auto mb-4" aria-hidden="true">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 00.495-7.467 5.99 5.99 0 00-1.925 3.546 5.974 5.974 0 01-2.133-1A3.75 3.75 0 0012 18z" />
            </svg>
          </div>
          <h3 class="font-display text-lg font-bold text-brand-navy mb-2">Scratch Kitchen</h3>
          <p class="text-gray-600 text-sm">
            Everything made in-house from sauces and rubs to desserts and dressings.
          </p>
        </div>

        <div class="text-center">
          <div class="w-14 h-14 bg-brand-blue rounded-full flex items-center justify-center mx-auto mb-4" aria-hidden="true">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
            </svg>
          </div>
          <h3 class="font-display text-lg font-bold text-brand-navy mb-2">Allergen Safe</h3>
          <p class="text-gray-600 text-sm">
            Dedicated gluten-free fryers and a team trained on allergen protocols.
          </p>
        </div>

        <div class="text-center">
          <div class="w-14 h-14 bg-brand-blue rounded-full flex items-center justify-center mx-auto mb-4" aria-hidden="true">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
            </svg>
          </div>
          <h3 class="font-display text-lg font-bold text-brand-navy mb-2">Community First</h3>
          <p class="text-gray-600 text-sm">
            Pet-friendly patio, local craft beers, and a welcoming spot for everyone.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Awards -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display text-xl font-semibold text-gray-400 uppercase tracking-wider mb-8">
        Recognized By
      </h2>
      <div class="flex flex-wrap justify-center gap-12 items-center text-gray-400">
        <div class="text-center">
          <p class="font-display text-2xl font-bold text-brand-blue">5 Stars</p>
          <p class="text-sm mt-1">Yelp</p>
        </div>
        <div class="w-px h-10 bg-gray-200" aria-hidden="true"></div>
        <div class="text-center">
          <p class="font-display text-2xl font-bold text-brand-blue">Travelers' Choice</p>
          <p class="text-sm mt-1">TripAdvisor 2025</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-brand-blue text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display text-3xl font-bold mb-4">Ready to Eat?</h2>
      <p class="text-white/80 text-lg mb-8 max-w-xl mx-auto">
        Come taste what everyone's talking about. We're open daily, 11 AM to 8:30 PM.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/menu" class="btn-primary bg-white text-brand-blue hover:bg-brand-cream">See the Menu</a>
        <a href="/contact" class="btn-outline">Get Directions</a>
      </div>
    </div>
  </section>
</Layout>
